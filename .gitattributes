# Normalize line endings: LF in the repo, auto-converted on checkout.
* text=auto eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.icns binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary

# Lockfiles: treat as generated in diffs/linguist.
package-lock.json linguist-generated=true
